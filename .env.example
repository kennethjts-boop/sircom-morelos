RUN_INTERVAL_HOURS=6
RUN_ON_START=true

ALLOW_INSECURE_PUBLIC_SSL_FALLBACK=false

SCORING_STRICT_MODE=true
MIN_RISK_FOR_INDIVIDUAL_ALERT=ROJO

OUTPUT_DIR=outputs
LOCAL_STORAGE_DIR=data
