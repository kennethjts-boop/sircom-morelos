NODE_ENV=development
PORT=3001
APP_TIMEZONE=America/Mexico_City
LOG_LEVEL=info

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
